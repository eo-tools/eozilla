# ── Stage 1: build ────────────────────────────────────────────
FROM ghcr.io/prefix-dev/pixi:{{ pixi_version }}-bookworm-slim AS build

RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates \
 && update-ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR {{ workdir }}

COPY ./pyproject.toml ./pyproject.toml
COPY ./pixi.lock      ./pixi.lock
{% if has_packages_dir %}
COPY ./{{ packages_dirname }} ./{{ packages_dirname }}
{% endif %}
{% for cmd in build_commands %}
{{ cmd }}
{% endfor %}
RUN pixi install --locked -e {{ pixi_env }}
{% for cmd in post_install_commands %}
{{ cmd }}
{% endfor %}

# ── Stage 2: runtime ──────────────────────────────────────────
FROM {{ base_image }}
WORKDIR {{ workdir }}

RUN apt-get update && apt-get install -y --no-install-recommends \
{% for pkg in all_apt_packages %}
    {{ pkg }} \
{% endfor %}
    && rm -rf /var/lib/apt/lists/*

COPY --from=build {{ workdir }}/.pixi/envs/{{ pixi_env }} {{ workdir }}/.pixi/envs/{{ pixi_env }}
{% if has_packages_dir and not post_install_commands %}
COPY --from=build {{ workdir }}/{{ packages_dirname }} {{ workdir }}/{{ packages_dirname }}
{% endif %}
COPY --from=build {{ workdir }}/pyproject.toml     {{ workdir }}/pyproject.toml
COPY --from=build {{ workdir }}/pixi.lock          {{ workdir }}/pixi.lock

COPY ./run_step.py {{ workdir }}/run_step.py
{% if runtime_commands %}

{% for cmd in runtime_commands %}
{{ cmd }}
{% endfor %}
{% endif %}

ENV PIXI_ENV="{{ workdir }}/.pixi/envs/{{ pixi_env }}"
ENV PIXI_PROJECT_ROOT="{{ workdir }}"
ENV PATH="$PIXI_ENV/bin:$PATH"
ENV LD_LIBRARY_PATH="$PIXI_ENV/lib:$LD_LIBRARY_PATH"
ENV PROJ_DATA="$PIXI_ENV/share/proj"
ENV XDG_CACHE_HOME="{{ workdir }}/cache"

ENTRYPOINT ["python", "{{ workdir }}/run_step.py"]
